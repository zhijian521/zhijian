{
    "name": "zhijian-site",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "typecheck": "tsc --noEmit",
        "docs:check": "node scripts/docs-check.mjs",
        "check": "npm run lint && npm run typecheck && npm run docs:check",
        "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"docs/**/*.md\" \"*.{json,md}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"docs/**/*.md\" \"*.{json,md}\"",
        "db:seed": "node sql/seed-admin.mjs"
    },
    "dependencies": {
        "archiver": "^8.0.0",
        "bcryptjs": "^3.0.3",
        "clsx": "^2.1.1",
        "highlight.js": "^11.11.1",
        "ip2region": "^2.3.0",
        "mysql2": "3.15.3",
        "next": "15.3.8",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-markdown": "^10.1.0",
        "recharts": "^3.8.1",
        "rehype-highlight": "^7.0.2",
        "remark-gfm": "^4.0.1"
    },
    "devDependencies": {
        "@types/archiver": "^8.0.0",
        "@types/node": "22.15.30",
        "@types/react": "19.1.6",
        "@types/react-dom": "19.1.5",
        "eslint": "^8.57.1",
        "eslint-config-next": "^15.5.20",
        "prettier": "^3.9.4",
        "typescript": "5.8.3"
    }
}
