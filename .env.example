## 站点地址（用于 OG 标签、sitemap、绝对 URL 生成）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

## 监控脚本分发地址（部署到哪个域名，脚本就从哪个域名加载）
## 不配置时回退到 NEXT_PUBLIC_SITE_URL
## 例：部署到 yuwb.cn，被监控网站加载 yuwb.cn/script.js
NEXT_PUBLIC_SCRIPT_URL=http://localhost:3000

## MySQL 连接串
DATABASE_URL=mysql://username:password@your-host:3306/your_database

## 后台管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

## 后台登录态签名密钥
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

## IndexNow API Key（用于主动通知搜索引擎收录，任意随机字符串）
## 验证文件需放在 public/{key}.txt，内容为 key 本身
INDEXNOW_API_KEY=

## 百度站长平台验证的站点域名（需与百度后台一致，如 https://www.yuwb.dev）
BAIDU_SITE=

## 百度站长平台 URL 提交 Token
BAIDU_SUBMISSION_TOKEN=

## DeepSeek API Key（导航页 AI 对话，留空则 AI 功能不可用）
## 获取：https://platform.deepseek.com/
DEEPSEEK_API_KEY=

## DeepSeek 模型（可选，默认 deepseek-chat）
## 用户仍可在导航页 AI 屏顶部下拉切换，此处为初始默认值
## 常用：deepseek-chat（通用）/ deepseek-reasoner（推理）
DEEPSEEK_MODEL=

## GitHub Token（可选，首页 Git 提交热力图拉取仓库提交记录）
## 未配置时热力图不显示数据
GITHUB_TOKEN=
